{
  "manifest_version": 3,
  "name": "TimeFlow",
  "version": "1.0",
  "description": "Gerencie múltiplos cronômetros com persistência",
  "permissions": ["storage", "tabs", "tabGroups"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-32.png",
    "128": "icon-128.png"
  }
}