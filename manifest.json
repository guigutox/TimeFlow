{
  "manifest_version": 3,
  "name": "TimeFlow",
  "version": "1.0",
  "description": "Gerencie múltiplos cronômetros com persistência",
  "permissions": ["storage", "tabs", "tabGroups"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "assets/icons/icon-16.png"
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-32.png",
    "128": "assets/icons/icon-128.png"
  }
}